NAHDA_APP_ENV=development
NAHDA_DATABASE_URL=postgresql+psycopg://nahda:nahda@localhost:5432/nahda
NAHDA_SQL_POOL_SIZE=10
NAHDA_SQL_MAX_OVERFLOW=20
NAHDA_SQL_POOL_TIMEOUT=30
NAHDA_SQL_POOL_RECYCLE=1800
NAHDA_AUTH_ENABLED=true
NAHDA_AUTH_JWT_SECRET=change-me-in-production-32-bytes-min
NAHDA_AUTH_JWT_ALGORITHM=HS256
NAHDA_AUTH_ACCESS_TOKEN_EXP_MINUTES=60
NAHDA_AUTH_BOOTSTRAP_KEY=local-dev-bootstrap-key
NAHDA_RATE_LIMIT_ENABLED=true
NAHDA_RATE_LIMIT_REQUESTS_PER_WINDOW=120
NAHDA_RATE_LIMIT_WINDOW_SECONDS=60
NAHDA_OBSERVABILITY_ENABLED=true
NAHDA_OBSERVABILITY_INCLUDE_PATH_LABELS=true
NAHDA_OTEL_ENABLED=true
NAHDA_OTEL_SERVICE_NAME=nahda-engine
NAHDA_OTEL_EXPORTER=none
NAHDA_OTEL_OTLP_ENDPOINT=http://localhost:4318/v1/traces
NAHDA_OTEL_SAMPLING_RATIO=1.0

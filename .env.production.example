NAHDA_APP_ENV=production
NAHDA_SECRET_PROVIDER=secret-manager

# Database (managed Postgres)
NAHDA_DATABASE_URL=postgresql+psycopg://nahda_app:${NAHDA_DB_PASSWORD}@prod-db:5432/nahda
NAHDA_SQL_POOL_SIZE=30
NAHDA_SQL_MAX_OVERFLOW=60
NAHDA_SQL_POOL_TIMEOUT=30
NAHDA_SQL_POOL_RECYCLE=1800

# Auth
NAHDA_AUTH_ENABLED=true
NAHDA_AUTH_JWT_SECRET=REPLACE_WITH_64_PLUS_CHAR_RANDOM_SECRET
NAHDA_AUTH_JWT_ALGORITHM=HS256
NAHDA_AUTH_ACCESS_TOKEN_EXP_MINUTES=30
NAHDA_AUTH_BOOTSTRAP_KEY=REPLACE_WITH_ROTATED_BOOTSTRAP_KEY

# Rate limiting
NAHDA_RATE_LIMIT_ENABLED=true
NAHDA_RATE_LIMIT_REQUESTS_PER_WINDOW=300
NAHDA_RATE_LIMIT_WINDOW_SECONDS=60

# Observability + tracing
NAHDA_OBSERVABILITY_ENABLED=true
NAHDA_OBSERVABILITY_INCLUDE_PATH_LABELS=true
NAHDA_OTEL_ENABLED=true
NAHDA_OTEL_SERVICE_NAME=nahda-engine
NAHDA_OTEL_EXPORTER=otlp
NAHDA_OTEL_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
NAHDA_OTEL_SAMPLING_RATIO=0.2

# Alert channels
NAHDA_ALERT_WEBHOOK_URL=https://alerts.example.internal/webhook
NAHDA_ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME
